# Frontend Environment Variables Template
# Copy this file to .env.local for development

# ===== BACKEND API URL =====
# Development (local backend)
REACT_APP_BACKEND_URL=http://localhost:8000

# Production (update with your deployed backend URL)
# REACT_APP_BACKEND_URL=https://your-backend-url.onrender.com

# ===== FIREBASE AUTHENTICATION =====
# Get these values from Firebase Console > Project Settings > General
# https://console.firebase.google.com/
REACT_APP_FIREBASE_API_KEY=your-firebase-api-key
REACT_APP_FIREBASE_AUTH_DOMAIN=your-app.firebaseapp.com
REACT_APP_FIREBASE_PROJECT_ID=your-project-id
REACT_APP_FIREBASE_STORAGE_BUCKET=your-app.appspot.com
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=123456789
REACT_APP_FIREBASE_APP_ID=1:123456789:web:abcdef123456

# ===== OPTIONAL API KEYS =====
# Google Maps API Key
# Get from: https://console.cloud.google.com/apis/credentials
# Enable: Maps JavaScript API, Geocoding API, Places API
REACT_APP_GOOGLE_MAPS_API_KEY=

# Mapbox Access Token (alternative to Google Maps)
# Get from: https://account.mapbox.com/
REACT_APP_MAPBOX_ACCESS_TOKEN=

# ===== FEATURE FLAGS =====
REACT_APP_ENABLE_VISUAL_EDITS=false
REACT_APP_ENABLE_SERVICE_WORKER=false
ENABLE_HEALTH_CHECK=false

# ===== BUILD SETTINGS =====
# Disable source map generation in production
GENERATE_SOURCEMAP=false
